{
  "manifest_version": 3,
  "name": "Simple Ad Blocker",
  "version": "1.4.0",
  "description": "MV3 기반 오픈소스 광고 차단기. 광고/추적 도메인 차단 + 유튜브 광고 자동 스킵.",
  "author": "skrkty",
  "permissions": ["declarativeNetRequest"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_block_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["hide_ads.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],
      "js": ["youtube_skip.js"],
      "css": ["youtube_ads.css"],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ]
}
